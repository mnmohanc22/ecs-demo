# =============================================================
# Backend Environment Configuration — Example / Template
# Copy this file to .env and fill in real values.
# .env is git-ignored and never baked into the Docker image.
# =============================================================

# ── Database connection ───────────────────────────────────────
DB_HOST=your-rds.cluster-xxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=appuser
DB_NAME=appdb
DB_PASSWORD=changeme
DB_SSLMODE=require

# ── AWS Secrets Manager (production) ─────────────────────────
# Set SECRET_NAME to fetch DB_PASSWORD from Secrets Manager at
# container startup (via entrypoint.sh).  The secret JSON must
# contain a "password", "DB_PASSWORD", or "db_password" key.
# When set, DB_PASSWORD above is ignored / overwritten.
# SECRET_NAME=prod/ecs-demo/db-credentials
AWS_REGION=us-east-1

# ── Application ───────────────────────────────────────────────
FLASK_ENV=production
PORT=5000
LOG_LEVEL=INFO
LOG_FORMAT=json
